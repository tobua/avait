{
  "name": "avait",
  "description": "Async error handling and fetch without try-catch.",
  "version": "0.0.0-development",
  "repository": "github:tobua/avait",
  "license": "MIT",
  "author": "Matthias Giger",
  "scripts": {
    "check": "biome check --write .",
    "types": "tsc && tsc --project ./test/tsconfig.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@elysiajs/cors": "^1.4.2",
    "@types/bun": "^1.3.14",
    "axios": "^1.18.1",
    "elysia": "^1.4.29",
    "node-fetch": "^3.3.2",
    "typescript": "^7.0.2",
    "zero-configuration": "^1.1.3"
  },
  "trustedDependencies": [
    "zero-configuration"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "types": "./index.ts",
  "files": [
    "*.ts"
  ],
  "keywords": [
    "await",
    "asynchronous",
    "fetch"
  ],
  "publishConfig": {
    "provenance": true
  },
  "configuration": {
    "gitignore": "recommended",
    "vscode": "biome",
    "biome": [
      {
        "extends": "recommended",
        "linter": {
          "rules": {
            "suspicious": {
              "noExplicitAny": "off"
            },
            "complexity": {
              "noBannedTypes": "off"
            }
          }
        },
        "files": {
          "includes": [
            "**/*",
            "!test"
          ]
        }
      },
      {
        "folder": "test",
        "extends": "test",
        "root": false,
        "files": {
          "includes": [
            "*.ts"
          ]
        }
      }
    ],
    "typescript": [
      {
        "extends": "plugin",
        "files": [
          "index.ts"
        ]
      },
      {
        "extends": "plugin",
        "folder": "test",
        "compilerOptions": {
          "strict": false
        }
      }
    ]
  }
}
